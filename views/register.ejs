<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <a class="navbar-brand" href="/">Home</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/users/login">Login</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/users/register">Register</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/fields">Fields</a>
                </li>
                <!-- Add more navigation links as needed -->
                
                <li class="nav-item">
                    <a class="nav-link" href="/profile">Profile</a>
                </li>
            
            </ul>
        </div>
    </nav>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Registration</title>
    <!-- Include Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Apply styles to the entire page */
        body {
            background-image: url('/bgImage/loginpage.jpg'); /* Assuming 'homepage.jpg' is your background image */
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: Arial, sans-serif;
            background-color: #fff; /* White background color */
            color: #2848a7; /* Green text color */
            margin: 0;
            padding: 0;
            text-align: center;
        }

        .container {
            background-color: #fff; /* White background color for the form container */
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
            width: 400px;
            margin: 0 auto;
            margin-top: 20px; /* Add some spacing to the top of the form container */
        }

        h1 {
            color: #284ea7; /* Green color for the heading */
            margin-top: 20px; /* Add some spacing to the top of the heading */
        }

        /* Rest of your CSS styles for form elements, labels, and links */

        .form-label {
            color: #3728a7; /* Green color for form labels */
            font-size: 18px;
            font-weight: bold;
        }

        .form-control {
            width: 100%;
            padding: 10px;
            margin-bottom: 15px;
            border: 1px solid #2835a7; /* Green border for form controls */
            border-radius: 3px;
            font-size: 16px;
        }

        .btn-primary {
            background-color: #2846a7; /* Button background color */
            color: #fff;
            padding: 10px 20px;
            border: none;
            border-radius: 3px;
            font-size: 18px;
            cursor: pointer;
        }

        .btn-primary:hover {
            background-color: #212688; /* Button hover background color */
        }

        /* Adjust the link color to make it visible */
        .login-link {
            font-size: 14px;
            color: #282ea7; /* Green link color */
            text-decoration: none;
        }
        
        .error-message {
            color: red; /* Red color for error messages */
            font-size: 16px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <h1>User Registration</h1>
    <ul>
        <% if (typeof errors != 'undefined') { %>
            <% errors.forEach(error => { %>
                <li><%= error.message %></li>
            <% }) %>
        <% } %>
    </ul>
    <div class="container">
        <form action="/users/register" method="POST">
            <div class="mb-3">
                <label for="First_Name" class="form-label">First Name:</label>
                <input type="text" class="form-control" id="First_Name" name="First_Name" required>
            </div>

            <div class="mb-3">
                <label for="Last_Name" class="form-label">Last Name:</label>
                <input type="text" class="form-control" id="Last_Name" name="Last_Name" required>
            </div>

            <div class="mb-3">
                <label for="Date_of_Birth" class="form-label">Date of Birth:</label>
                <input type="date" class="form-control" id="Date_of_Birth" name="Date_of_Birth" required>
            </div>

            <div class="mb-3">
                <label for="Email" class="form-label">Email:</label>
                <input type="email" class="form-control" id="Email" name="Email" required>
            </div>

            <div class="mb-3">
                <label for="Pass" class="form-label">Password:</label>
                <input type="password" class="form-control" id="Pass" name="Pass" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Select User Type:</label>
                <div class="form-check">
                    <input type="radio" class="form-check-input" id="Is_Student" name="User_Type" value="student" checked>
                    <label class="form-check-label" for="Is_Student">Student</label>
                </div>
                <div class="form-check">
                    <input type="radio" class="form-check-input" id="Is_Instructor" name="User_Type" value="instructor">
                    <label class="form-check-label" for="Is_Instructor">Instructor</label>
                </div>
            </div>

            <!-- Bank Account field, initially hidden -->
            <div class="mb-3" id="bankAccountField" style="display: none;">
                <label for="Bank_Account" class="form-label">Bank Account:</label>
                <input type="text" class="form-control" id="Bank_Account" name="Bank_Account">
            </div>

            <button type="submit" class="btn btn-primary">Register</button>
        </form>
        <!-- Add a link to the login page -->
        <p class="mt-3">Already have an account? <a class="login-link" href="/users/login">Login here</a></p>
    </div>

    <!-- Include Bootstrap JavaScript (optional) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap/dist/js/bootstrap.min.js"></script>
    <script>
        // Function to toggle bank account field visibility based on user selection
        function toggleBankAccountField() {
            const instructorRadio = document.getElementById("Is_Instructor");
            const bankAccountField = document.getElementById("bankAccountField");

            if (instructorRadio.checked) {
                bankAccountField.style.display = "block";
            } else {
                bankAccountField.style.display = "none";
            }
        }

        // Add event listener to radio buttons to toggle bank account field visibility
        const instructorRadio = document.getElementById("Is_Instructor");
        const studentRadio = document.getElementById("Is_Student");
        instructorRadio.addEventListener("change", toggleBankAccountField);
        studentRadio.addEventListener("change", toggleBankAccountField);

        // Initialize bank account field visibility
        toggleBankAccountField();
    </script>
</body>
</html>
