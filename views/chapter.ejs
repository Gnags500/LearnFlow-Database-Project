<!DOCTYPE html>
<html>
<head>
  <title>Chapter Materials</title>
  <style>
    body {
        background-image: url('/bgImage/insprofile.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        height: 100vh;
        margin: 0;
        padding: 0;
        background-color: white;
        color: darkblue;
        font-family: Arial, sans-serif;
        padding: 20px;
    }

    .container {
        max-width: 1200px;
    }

    h1,
    h2,
    h3 {
        font-weight: bold;
        color: darkblue;
    }

    .box {
    background-color: #f0faff;
    padding: 20px;
    border-radius: 5px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    margin-bottom: 20px;
    max-width: 800px; /* Adjust the max-width as needed */
    margin: 0 auto; /* Centers the box on the page */
}

    .courses-container {
        margin-top: 20px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        grid-gap: 20px;
    }

    .course-item {
        background-color: #f0faff;
        padding: 20px;
        border-radius: 5px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

    .description-box {
        background-color: white;
        padding: 20px;
        border-radius: 5px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

    .course-item h3 {
        margin-top: 0;
    }

    .course-item p {
        margin-bottom: 0;
    }

    p.no-courses {
        color: #ffcccc;
    }

    .course-img {
        max-width: 100%;
        height: auto;
        border-radius: 5px;
        margin-bottom: 10px;
    }

    .field-img {
        max-width: 300px;
        height: auto;
        border-radius: 5px;
        margin-bottom: 10px;
    }

    .add-chapter-form {
    display: none; /* Hide the form by default */
}
</style>
</head>
<body>
  <!-- Display the materials -->
  <div class="box">
    <h1>Chapter Materials</h1>
    <% materials.forEach(material => { %>
      <p><%= material.note %></p>
      <% if (material.material_type === 'pdf') { %>
        <a href="<%= material.link_to_resource %>" download>Download PDF</a>
      <% } else if (material.material_type === 'video') { %>
        <iframe width="560" height="315" src="<%= material.link_to_resource %>" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
      <% } %>
    <% }); %>
  </div>

  <!-- Allow instructor to add new materials -->
  <% if (user.is_instructor) { %>
    <div class="box">
      <h2>Add New Material</h2>
      <form action="/course/<%= courseId %>/chapter/<%= chapterId %>/addMaterial" method="post">
        <label for="material_description">Note:</label>
        <input type="text" id="material_description" name="material_description"><br><br>

        <label for="material_type">Material Type:</label>
        <select id="material_type" name="material_type">
          <option value="pdf">PDF</option>
          <option value="video">Video</option>
        </select><br><br>

        <label for="link_to_resource">Link To Resource:</label>
        <input type="text" id="link_to_resource" name="link_to_resource"><br><br>

        <input type="submit" value="Add Material">
      </form>
    </div>
  <% } %>
</body>
</html>
