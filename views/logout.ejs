                </li>
            
                <!-- Add more navigation links as needed -->
            </ul>
        </div>
    </nav>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logout</title>
    <style>
        /* Apply styles to the entire page */
        body {
          /* background-image: url('/bgImage/homepage.png'); /* Assuming 'homepage.jpg' is your background image */
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: Arial, sans-serif;
            background-color: #fefeff; /* Green background color */
            color:black ;/* White text color */
            margin: 0;
            padding: 0;
            text-align: center;
        }

        h1 {
            margin-top: 20px; /* Add some spacing to the top of the heading */
        }

        .logout-message {
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
            width: 300px;
            margin: 0 auto;
            border: 1px solid #2835a7; /* Green border for message box */
            border-radius: 3px;
            font-size: 16px;
            background-color: #fff; /* White background color for message box */
            color: #333333; /* Text color for message box */
        }

        input[type="submit"] {
            background-color: #fff; /* White button background color */
            color: #2848a7; /* Green button text color */
            padding: 10px 20px;
            border: none;
            border-radius: 3px;
            font-size: 18px;
            cursor: pointer;
        }

        input[type="submit"]:hover {
            background-color: #e6e6e6; /* Light gray button hover background color */
        }
    </style>
</head>
<body>
    <h1>Logout</h1>
    <div class="logout-message">
        <p>You are already logged in, click here to log out.</p>
        <form action="/users/logout" method="GET">
            <input type="submit" value="Logout">
        </form>
    </div>
</body>
</html>
