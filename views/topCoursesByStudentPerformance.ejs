<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Top Courses by Student Performance</title>
    <style>
        body {
            background-image: url('/bgImage/homepage.avif');  
            background-color: white;
            color: darkblue;
            font-family: Arial, sans-serif;
            padding: 20px;
        }

        h1, h2 {
            color: darkblue;
            margin-bottom: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        th, td {
            padding: 8px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        th {
            background-color: #f2f2f2;
        }
    </style>
    <!-- Include additional styles -->
    <style>
        /* Add additional styles here */
    </style>
</head>
<body>
    <h1>Top Courses by Student Performance</h1>

    <% if (topCoursesByStudentPerformance.length === 0) { %>
        <p>No courses available.</p>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>Course ID</th>
                    <th>Course Title</th>
                    <th>Average Grade</th>
                </tr>
            </thead>
            <tbody>
                <% topCoursesByStudentPerformance.forEach(course => { %>
                    <tr>
                        <td><%= course.course_id %></td>
                        <td><a href="/course/<%= course.course_id %>"><%= course.course_title %></a></td>
                        <td><%= course.average_grade %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>
</body>
</html>
